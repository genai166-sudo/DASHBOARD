# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키를 입력하세요.
# .env 는 .gitignore / .cursorignore 에 등록되어 Git·AI에 노출되지 않습니다.
#
# Windows:  copy .env.example .env

# Tavily — https://app.tavily.com/
TAVILY_API_KEY=

# ExchangeRate-API — https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# Naver 검색 API — https://developers.naver.com/apps/#/list
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 공공데이터포털 (data.go.kr) — https://www.data.go.kr/
# 방위사업청_군수품조달정보 입찰공고_GW (getDmstcCmpetBidPblancList)
# 마이페이지 > 활용신청 후 발급 · 일반인증키 Decoding 권장
DATA_GO_KR_SERVICE_KEY=

# ── Kakao — AI 분석 결과 카카오톡 「나에게 보내기」 ──
# 개발자 콘솔: https://developers.kakao.com/console/app
# 앱 > 제품 설정 > 카카오 로그인 활성화 + Redirect URI 등록
# 앱 > 제품 설정 > 카카오톡 메시지 > 「나에게 보내기」 활성화
# 동의 항목: talk_message (카카오톡 메시지 전송)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/kakao/oauth/callback

# OAuth 1회 인증 후 발급 (서버가 자동 전송하려면 필수)
# /api/kakao/oauth/login → 카카오 로그인 → 콜백 화면의 refresh_token 복사
# 로컬: .data/kakao-token.json 자동 저장 가능
# Vercel: 파일 저장 불가 → 반드시 Environment Variables에 등록 후 재배포
KAKAO_REFRESH_TOKEN=

# 선택 — AI 분석 완료 시 자동 전송 (true / false)
KAKAO_SEND_ON_AI_ANALYSIS=false

# 선택 — 대시보드 공개 URL (메시지 링크·Vercel OAuth 콜백용)
# 로컬: http://localhost:3000  ·  배포: https://your-app.vercel.app
DASHBOARD_PUBLIC_URL=http://localhost:3000
